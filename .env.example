# ── Copy this file to cac-backend/.env and fill in real values ──────────────
# NEVER commit the actual .env file — it is in .gitignore

# ── Server ────────────────────────────────────────────
NODE_ENV=production

# ── MongoDB Atlas ─────────────────────────────────────
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/cac_couriers?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=generate_this_using_node_command
JWT_EXPIRES_IN=9999d

# ── Admin account (auto-created on first run) ─────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChooseAStrongPassword

# ── Email / Nodemailer (Gmail App Password) ───────────
MAIL_HOST=smtp.yourdomain.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@domain.com
MAIL_PASS=your_email_app_password
MAIL_FROM="Your Company" <your_email@domain.com>
ADMIN_NOTIFY_EMAIL=your_email@domain.com

# ── CORS ──────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API.
FRONTEND_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# ── Misc ──────────────────────────────────────────────
COMPANY_NAME=Your Company Name
TRACKING_BASE_URL=https://yourdomain.com/tracking-result.html

# ── Misc ──────────────────────────────────────────────
COMPANY_NAME=CAC Couriers & Shipping Company
TRACKING_BASE_URL=https://www.caclogistics.site/tracking-result.html
