# ── Copy this file to cac-backend/.env and fill in real values ──────────────
# NEVER commit the actual .env file — it is in .gitignore

# ── Server ────────────────────────────────────────────
NODE_ENV=production

# ── MongoDB Atlas ─────────────────────────────────────
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://admincapable:AdminRG@cluster0.xcvrajg.mongodb.net/cac_couriers?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=9999d

# ── Admin account (auto-created on first run) ─────────
ADMIN_EMAIL=admin@caclogistics.site
ADMIN_PASSWORD=your_admin_password_here

# ── Email / Nodemailer (Gmail App Password) ───────────
MAIL_HOST=smtp.caclogistics.site
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=info@caclogistics.site
MAIL_PASS=your_mail_password_here
MAIL_FROM="CAC Couriers" <info@caclogistics.site>
ADMIN_NOTIFY_EMAIL=info@caclogistics.site

# ── CORS ──────────────────────────────────────────────
# Comma-separated list of frontend origins allowed to call the API.
# When frontend and backend share one Railway service, this can be left blank
# because same-origin requests have no Origin header and are always allowed.
# Only needed when your frontend is on a DIFFERENT domain:
FRONTEND_ORIGIN=https://caclogistics.site,https://www.caclogistics.site

# ── Misc ──────────────────────────────────────────────
COMPANY_NAME=CAC Couriers & Shipping Company
TRACKING_BASE_URL=https://www.caclogistics.site/tracking-result.html
